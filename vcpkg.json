{
  "name": "gqlxy-client",
  "version": "0.1.0",
  "description": "C++ GraphQL client with HTTP/WS/SSE support, ReactivePlusPlus reactivity, and C++20 coroutines",
  "homepage": "https://github.com/KaSSaaaa/gqlxy-client",
  "license": "MIT",
  "supports": "!uwp",
  "configuration": {
    "default-registry": {
      "kind": "builtin",
      "baseline": "e5a1490e1409d175932ef6014519e9ae149ddb7c"
    },
    "registries": [
      {
        "kind": "git",
        "repository": "https://github.com/KaSSaaaa/vcpkg.git",
        "reference": "feature/gqlxy",
        "baseline": "e330cf6d2350205c4249e60e632210b13151bafb",
        "packages": [
          "gqlxy-*"
        ]
      }
    ]
  },
  "dependencies": [
    "gqlxy-core",
    "reactiveplusplus",
    "nlohmann-json",
    "boost-beast",
    "boost-url",
    "boost-uuid",
    "openssl",
    "cppgraphqlgen",
    "pegtl",
    "better-enums"
  ],
  "features": {
    "tests": {
      "description": "Build and run the test suite",
      "dependencies": [
        "gtest",
        "oatpp",
        "oatpp-websocket",
        "oatpp-openssl",
        {
          "name": "gqlxy-server",
          "features": ["standalone-server"]
        }
      ]
    },
    "samples": {
      "description": "Build sample applications",
      "dependencies": [
        "ftxui"
      ]
    }
  }
}
