{
  "name": "gqlxy-client",
  "version": "0.1.0",
  "description": "C++ GraphQL client with HTTP/WS/SSE support, ReactivePlusPlus reactivity, and C++20 coroutines",
  "homepage": "https://github.com/KaSSaaaa/gqlxy-client",
  "license": "MIT",
  "supports": "!uwp",
  "dependencies": [
    "gqlxy-core",
    "reactiveplusplus",
    "nlohmann-json",
    "boost-beast",
    "boost-url",
    "boost-uuid",
    "openssl",
    "cppgraphqlgen",
    "pegtl",
    "better-enums"
  ],
  "features": {
    "tests": {
      "description": "Build and run the test suite",
      "dependencies": [
        "gtest",
        "oatpp",
        "oatpp-websocket",
        "oatpp-openssl",
        {
          "name": "gqlxy-server",
          "features": ["standalone-server"]
        }
      ]
    },
    "samples": {
      "description": "Build sample applications",
      "dependencies": [
        "ftxui"
      ]
    }
  }
}
